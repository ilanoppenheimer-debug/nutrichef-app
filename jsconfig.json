{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "checkJs": false,
    "noEmit": true
  },
  "include": ["src/**/*", "server/**/*", "vite.config.js", "eslint.config.js"]
}
